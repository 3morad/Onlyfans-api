# ---- OnlyFans API (https://app.onlyfansapi.com) ----
# Create a key in the OnlyFansAPI dashboard -> API Keys.
ONLYFANS_API_KEY=
# Base URL. Leave as-is unless OnlyFansAPI tells you otherwise.
ONLYFANS_API_BASE=https://app.onlyfansapi.com/api

# ---- Airtable ----
# Personal Access Token from https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=apppn8mDeO3pvAFpc
# Cumulative (per-campaign) table and the daily (per-day) table.
AIRTABLE_TABLE_NAME=SFS Tracking
AIRTABLE_DAILY_TABLE=SFS Daily

# ---- Sync behaviour ----
# Only tracking links whose campaign name starts with this prefix are synced.
SFS_PREFIX=New SFS
# Log a daily row for every day since campaign creation (true) or only days
# that had activity (false).
INCLUDE_ZERO_DAYS=true
